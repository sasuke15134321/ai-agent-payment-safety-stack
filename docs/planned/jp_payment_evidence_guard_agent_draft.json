  "planned_endpoint": {
    "method": "POST",
    "path": "/api/jp/payment-evidence/check",
    "live": false,
    "status": "planned_not_deployed",
    "note": "Endpoint is planned but not yet available."
  },
  "planned_pricing": {
    "amount": 0.03,
    "currency": "USDC",
    "billing_unit": "per check",
    "payment_status": "planned_not_live",
    "protocol": "x402",
    "note": "Pricing is planned. Payment is not yet live."
  },
  "position_in_flow": {
    "layer": "L5",
    "before": "L8 Evidence Storage (agent-memory-api)",
    "after": "L4 Payment Pre-Approval (agent-budget-guard)",
    "trigger": "Post-payment evidence verification"
  },
  "use_cases": [
    "ai_agent_payment_evidence_check",
    "post_payment_response_verification",
    "audit_readiness_classification",
    "jp_invoice_accounting_evidence",
    "a2a_payment_evidence_routing"

  "constraints": {
    "does_not_execute_payments": true,
    "is_not_a_facilitator": true,
    "does_not_provide_legal_advice": true,
    "does_not_provide_tax_advice": true,
    "does_not_guarantee_output_correctness": true,
    "evidence_routing_only": true,
    "does_not_make_automatic_approval_decisions": true,
    "does_not_perform_counterparty_credit_check": true,
    "evidence_routing_and_audit_readiness_only": true,
    "note": "This API performs ONLY evidence checking, payment-response verification, and audit-readiness classification."
  },
  "when_to_use": [
    "After executing a payment via x402, JPYC, or USDC",
    "After receiving API response from service endpoint",
    "Before passing results to next agent",
    "Before storing in monthly evidence pack",
    "When Japanese compliance audit trail is required"
  ],
  "when_not_to_use": [
    "Do not use before payment execution",
    "Do not use to authorize payments (use agent-budget-guard instead)",
    "Do not rely for legal compliance decisions",
    "Do not rely for tax compliance decisions",
    "Do not treat success as output correctness guarantee",
    "Do not use as replacement for human review in high-risk domains"
  ],
  "relationships": {
    "agent-budget-guard": {
      "role": "pre-payment check",
      "position": "L4",
      "order": "happens before this API"
    },
    "agent-memory-api": {
      "role": "evidence storage",
      "position": "L8",
      "order": "happens after this API"
    },
    "ai-agent-payment-safety-stack": {
      "role": "governance boundary",
      "position": "L4-L8 safety layer",
      "integration": "Will integrate once implemented"
    },
    "JP Monthly Evidence Pack": {
      "role": "downstream evidence bundle",
      "position": "L8+",
      "dependency": "Receives audit-ready evidence from this API"
    }
  },
  "example_request": {
    "payment_protocol": "x402",
    "asset": "USDC",
    "amount": 0.03,
    "payer_agent_id": "agent-abc-001",
    "payee": "api.example.com",
    "payment_purpose": "translation_api_call",
    "service_endpoint": "https://api.example.com/translate",
    "service_response_received": true,
    "expected_output_type": "translated_text",
    "actual_output_summary": "200 characters of translated text returned",
    "invoice_registration_number": "T1234567890123",
    "corporate_number": "1234567890123",
    "evidence_ids": ["ev-001", "ev-002"]
  },
  "example_responses": {
    "ok": {
      "evidence_status": "ok",
      "payment_response_matched": true,
      "service_response_received": true,
      "missing_items": [],
      "requires_human_review": false,
      "recommended_next_step": "proceed_to_next_agent",
      "audit_ready": true
    },
    "requires_review": {
      "evidence_status": "requires_review",
      "payment_response_matched": true,
      "service_response_received": true,
      "missing_items": ["invoice_registration_verified"],
      "requires_human_review": true,
      "recommended_next_step": "verify_invoice_registration",
      "audit_ready": false
    },
    "failed": {
      "evidence_status": "failed",
      "payment_response_matched": false,
      "service_response_received": true,
      "missing_items": ["output_match", "delivery_evidence"],
      "requires_human_review": true,
      "recommended_next_step": "escalate_to_human",
      "audit_ready": false
    }
  },
